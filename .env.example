# ─────────────────────────────────────────────────────────────────────────────
# Monster Fitness — Variáveis de Ambiente
#
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Substitua TODOS os valores por secrets reais
#   3. NUNCA faça commit do arquivo .env (está no .gitignore)
#   4. Em produção, use o gerenciador de secrets do seu provedor
#      (AWS Secrets Manager, Railway Variables, Doppler, etc.)
# ─────────────────────────────────────────────────────────────────────────────

# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SUBSTITUA_POR_64_CHARS_ALEATORIOS_AQUI

# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=SUBSTITUA_POR_OUTRO_64_CHARS_ALEATORIOS_AQUI

# Senha do usuário mf_user do MySQL (mínimo 16 chars, use especiais)
DB_PASSWORD=SUBSTITUA_POR_SENHA_FORTE_DO_BANCO

# Senha root do MySQL (use uma senha diferente do DB_PASSWORD)
DB_ROOT_PASSWORD=SUBSTITUA_POR_SENHA_ROOT_DIFERENTE
